# =============================================================================
# E-Botar — environment template (frontend + backend)
# =============================================================================
# Copy this file to `.env` at the repository root (same folder as this example):
#   E_Botar/.env
#
# Django loads (see backend/backend/settings.py):
#   1) E_Botar/.env
#   2) E_Botar/backend/.env  (optional; values here override the root file)
#
# Never commit real `.env` files — only this `.env.example`.
# =============================================================================

# -----------------------------------------------------------------------------
# Django (backend)
# -----------------------------------------------------------------------------

# Production gate — set True only on live servers.
IS_PRODUCTION=False

# Local dev: True. Production: False.
DEBUG=True

# Required in production. Generate:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Optional. If empty, Django uses SQLite at backend/db.sqlite3
# Example (PostgreSQL): postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# Public URL of the API (scheme + host, no trailing path). Used for links / redirects where needed.
# Local: http://127.0.0.1:8000
BACKEND_BASE_URL=http://127.0.0.1:8000

# HTTPS redirect in production (behind TLS). Local: False
SECURE_SSL_REDIRECT=False

# -----------------------------------------------------------------------------
# Frontend (Vite) — production builds only
# -----------------------------------------------------------------------------
# In dev, the Vite proxy uses vite.config.js; this var is mainly for `npm run build`.
# Use the same origin you expose to browsers (no trailing slash required; /api is added in code).
#
# Examples:
#   VITE_API_BASE_URL=http://127.0.0.1:8000
#   VITE_API_BASE_URL=https://api.yourdomain.com
VITE_API_BASE_URL=http://127.0.0.1:8000
